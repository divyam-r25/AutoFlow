package com.autoflow.automation.models

/**
 * Represents the types of automation actions that AutoFlow can perform.
 * Each action maps to a specific gesture dispatched through the AccessibilityService.
 */
enum class ActionType {

    /** A single tap at a point. Default duration ~100ms. */
    CLICK,

    /** A sustained press at a point. Typically 500ms+. */
    LONG_PRESS,

    /** A drag gesture from one point to another. */
    SWIPE,

    /** A delay between actions. No gesture is dispatched. */
    WAIT
}
